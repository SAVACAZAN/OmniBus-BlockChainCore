import { invoke } from '@tauri-apps/api/core';
import { listen } from '@tauri-apps/api/event';
import { WebviewWindow } from '@tauri-apps/api/webviewWindow';

// ═══ CONSTANTS ═══
const SANDBOX = 'C:\\Kits work\\limaje de programare\\OmniBus aweb3 + OmniBus BlockChain';
const BC_ROOT = SANDBOX + '\\OmniBus-BlockChainCore';
const AWEB3_ROOT = SANDBOX + '\\OmniBus - aweb3';
const MYTHOS_DIR = BC_ROOT + '\\tools\\MYTHOS';
const MYTHOS_DATA = MYTHOS_DIR + '\\data';
const IMPORTED_DIR = MYTHOS_DIR + '\\imported';

// ═══ STATE ═══
let processCounter = 0;
const activeProcesses = new Map();
let currentFilePath = '';

// ═══ PAGE / TAB MANAGEMENT ═══
window.showPage = function(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  const page = document.getElementById('page-' + id);
  if (page) page.classList.add('active');

  document.querySelectorAll('.side-item').forEach(s => s.classList.remove('active'));
  if (event && event.target) {
    const item = event.target.closest('.side-item');
    if (item) item.classList.add('active');
  }

  const tabBar = document.getElementById('tabBar');
  if (!tabBar) return;
  const exists = tabBar.querySelector(`[data-page="${id}"]`);
  if (!exists) {
    const names = { dashboard: 'Dashboard', console: 'Console', claude: 'Claude', files: 'Files', agents: 'Agents', exploits: 'Exploit Lab', logs: 'Logs', history: 'History', settings: 'Settings', skills: 'Skills', learning: 'Learning' };
    const tab = document.createElement('div');
    tab.className = 'tab';
    tab.dataset.page = id;
    tab.onclick = function () { window.switchTab(this); };
    tab.innerHTML = `${names[id] || id} <span class="close" onclick="window.closeTab(event,this.parentElement)">&times;</span>`;
    tabBar.insertBefore(tab, tabBar.querySelector('.tab-add'));
  }
  window.switchTab(tabBar.querySelector(`[data-page="${id}"]`));

  // Lazy-load page data
  if (id === 'files') loadFileBrowser();
  if (id === 'agents') loadAgents();
  if (id === 'exploits') loadExploits();
};

window.switchTab = function (tab) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  tab.classList.add('active');
  const page = document.getElementById('page-' + tab.dataset.page);
  if (page) page.classList.add('active');
};

window.closeTab = function (e, tab) {
  e.stopPropagation();
  const wasActive = tab.classList.contains('active');
  tab.remove();
  if (wasActive) {
    const first = document.querySelector('.tab');
    if (first) window.switchTab(first);
  }
};

window.addTab = function () {
  window.openConsole('cmd');
};

// ═══ PANEL WINDOWS ═══
window.openPanelWindow = function (panelId) {
  const panels = {
    'dashboard': { url: '/pages/dashboard.html', title: 'MYTHOS Dashboard', w: 1400, h: 900 },
    'mythos-lab': { url: '/pages/mythos-lab-standalone.html', title: 'MYTHOS Lab Standalone', w: 1400, h: 900 },
    'deepseek-09bb60': { url: '/pages/deepseek_09bb60.html', title: 'DeepSeek 09bb60', w: 1200, h: 800 },
    'deepseek-1d78bd': { url: '/pages/deepseek_1d78bd.html', title: 'DeepSeek 1d78bd', w: 1200, h: 800 },
    'deepseek-7565c8': { url: '/pages/deepseek_7565c8.html', title: 'DeepSeek 7565c8', w: 1200, h: 800 },
  };
  const cfg = panels[panelId];
  if (!cfg) return;
  const label = 'panel_' + panelId + '_' + Date.now();
  const webview = new WebviewWindow(label, {
    url: cfg.url,
    title: cfg.title,
    width: cfg.w,
    height: cfg.h,
    resizable: true,
    decorations: true,
    center: true,
  });
  webview.once('tauri://created', () => {
    appendToConsole('main', `[INFO] Opened panel: ${cfg.title}`);
  });
  webview.once('tauri://error', (e) => {
    appendToConsole('main', `[ERROR] Failed to open panel: ${e.payload}`);
  });
};

// ═══ HTML TABS (iframe inside main app) ═══
window.openHtmlTab = function (url, title) {
  const tabId = 'htmltab_' + Date.now();
  const pageId = 'page-' + tabId;

  // Create page container with iframe
  const pagesContainer = document.querySelector('.pages');
  if (!pagesContainer) return;

  const pageDiv = document.createElement('div');
  pageDiv.className = 'page';
  pageDiv.id = pageId;
  pageDiv.style.padding = '0';
  pageDiv.innerHTML = `<iframe src="${url}" style="width:100%;height:100%;border:none;" sandbox="allow-scripts allow-same-origin allow-popups"></iframe>`;
  pagesContainer.appendChild(pageDiv);

  // Create tab
  const tabBar = document.getElementById('tabBar');
  if (!tabBar) return;
  const tab = document.createElement('div');
  tab.className = 'tab';
  tab.dataset.page = tabId;
  tab.onclick = function () { window.switchTab(this); };
  tab.innerHTML = `<span class="tab-icon">&#128196;</span> ${title} <span class="close" onclick="window.closeTab(event,this.parentElement)">&times;</span>`;
  tabBar.insertBefore(tab, tabBar.querySelector('.tab-add'));

  window.switchTab(tab);
  appendToConsole('main', `[INFO] Opened tab: ${title}`);
};

// ═══ CONSOLE / PROCESS MANAGEMENT ═══
window.openConsole = async function (type) {
  window.showPage('console');
  const sel = document.getElementById('consoleType');
  if (sel) sel.value = type === 'mythos' ? 'mythos' : (type === 'claude' ? 'claude' : type);

  if (type === 'claude') {
    // Launch Claude chat bridge as interactive process
    await spawnConsole('claude');
  } else if (type === 'kimi') {
    await spawnConsole('kimi');
  } else if (['cmd', 'python'].includes(type)) {
    await spawnConsole(type);
  }
};

async function spawnConsole(type) {
  const id = `proc_${++processCounter}`;
  let program, args, cwd;

  switch (type) {
    case 'cmd':
      program = 'cmd'; args = ['/k']; cwd = SANDBOX; break;
    case 'claude':
      program = 'python'; args = ['-u', 'tools/MYTHOS/claude-chat-bridge.py']; cwd = BC_ROOT; break;
    case 'python':
      program = 'python'; args = ['-i']; cwd = BC_ROOT; break;
    case 'mythos':
      program = 'python'; args = ['tools/MYTHOS/omnibus-mythos.py', '--phase', 'crypto']; cwd = BC_ROOT; break;
    case 'mythos-all':
      program = 'python'; args = ['tools/MYTHOS/omnibus-mythos.py']; cwd = BC_ROOT; break;
    default:
      program = 'cmd'; args = ['/k']; cwd = SANDBOX;
  }

  // Listen for output
  const unlistenOutput = await listen(`process-output-${id}`, (event) => {
    appendToConsole(id, event.payload);
  });
  const unlistenExit = await listen(`process-exit-${id}`, (event) => {
    appendToConsole(id, '\n[Process ended]');
  });

  activeProcesses.set(id, { unlistenOutput, unlistenExit });

  try {
    const result = await invoke('spawn_process', { program, args, workingDir: cwd, processId: id });
    appendToConsole(id, `[INFO] ${result}`);
  } catch (e) {
    appendToConsole(id, `[ERROR] ${e}`);
  }

  return id;
}

function appendToConsole(processId, line) {
  const output = document.getElementById('consoleOutput');
  if (!output) return;
  const div = document.createElement('div');
  const text = String(line);
  if (text.includes('[PASS]') || text.includes('PASS')) div.className = 'g';
  else if (text.includes('[FAIL]') || text.includes('FAIL')) div.className = 'r';
  else if (text.includes('[WARN]') || text.includes('WARN')) div.className = 'y';
  else if (text.includes('[INFO]') || text.includes('INFO')) div.className = 'c';
  else if (text.includes('PHASE:')) div.className = 'p';
  else if (text.startsWith('[ERROR]')) div.className = 'r';
  else div.className = 'd';
  div.textContent = text;
  output.appendChild(div);
  output.scrollTop = output.scrollHeight;
}

window.sendCmd = async function () {
  const input = document.getElementById('cmdInput');
  const cmd = input.value;
  if (!cmd) return;
  input.value = '';

  // Check if we're in Claude mode
  const sel = document.getElementById('consoleType');
  const isClaudeMode = sel && sel.value === 'claude';

  const isKimiMode = sel && sel.value === 'kimi';

  if (isClaudeMode || isKimiMode) {
    // Chat mode: send input to the running bridge process via stdin
    const activeId = Array.from(activeProcesses.keys()).pop();
    if (activeId) {
      try {
        await invoke('send_input', { processId: activeId, input: cmd });
      } catch (e) {
        appendToConsole('main', `[ERROR] send_input failed: ${e}`);
      }
    } else {
      appendToConsole('main', '[INFO] No chat process running. Click Claude Chat or Kimi Chat in sidebar first.');
    }
  } else {
    // Normal mode: send to active process or run as shell command
    appendToConsole('main', `$ ${cmd}`);

    const activeId = Array.from(activeProcesses.keys()).pop();
    if (activeId) {
      try {
        await invoke('send_input', { processId: activeId, input: cmd });
      } catch (e) {
        // If send_input fails, spawn new process with the command
        const parts = cmd.split(' ');
        const id = `cmd_${++processCounter}`;
        const unlistenOutput = await listen(`process-output-${id}`, (event) => {
          appendToConsole(id, event.payload);
        });
        const unlistenExit = await listen(`process-exit-${id}`, (event) => {
          appendToConsole(id, '[Process ended]');
        });
        activeProcesses.set(id, { unlistenOutput, unlistenExit });
        try {
          await invoke('spawn_process', {
            program: parts[0],
            args: parts.slice(1),
            workingDir: BC_ROOT,
            processId: id
          });
        } catch (e2) {
          appendToConsole('main', `[ERROR] ${e2}`);
        }
      }
    } else {
      appendToConsole('main', '[INFO] No active process. Use sidebar to open a terminal first.');
    }
  }
};

window.runInConsole = async function (cmd) {
  window.showPage('console');
  document.getElementById('cmdInput').value = cmd;
  await window.sendCmd();
};

window.clearConsole = function () {
  const output = document.getElementById('consoleOutput');
  if (output) output.innerHTML = '<div class="c">$ _</div>';
};

window.switchConsole = async function (type) {
  if (type === 'claude') {
    appendToConsole('chat', '[INFO] Switched to Claude Chat. Type message and press RUN.');
  } else if (type === 'kimi') {
    appendToConsole('chat', '[INFO] Switched to Kimi Chat. Type message and press RUN.');
  } else if (type === 'cmd' || type === 'python') {
    await spawnConsole(type);
  } else if (type === 'mythos') {
    await spawnConsole('mythos');
  }
};

// ═══ FILE BROWSER ═══
async function loadFileBrowser() {
  const filetree = document.querySelector('.filetree');
  if (!filetree) return;
  // Clear hardcoded tree and load real data
  filetree.innerHTML = '<div style="padding:8px 12px;font-weight:bold;font-size:11px;color:var(--accent);border-bottom:1px solid var(--border);">SANDBOX</div>';
  await renderDirectory(SANDBOX, filetree, 0);
}

async function renderDirectory(path, container, depth) {
  try {
    const entries = await invoke('read_directory', { path });
    for (const entry of entries) {
      const div = document.createElement('div');
      const padding = 12 + depth * 12;
      if (entry.is_dir) {
        div.className = 'dir';
        div.style.paddingLeft = padding + 'px';
        div.innerHTML = `<span class="arrow">&#9654;</span> ${entry.name}/ <span style="color:var(--t3);font-size:9px;">(${entry.children_count})</span>`;
        div.onclick = async () => {
          let sub = div.nextElementSibling;
          if (sub && sub.dataset.subdir === 'true') {
            sub.style.display = sub.style.display === 'none' ? 'block' : 'none';
            div.querySelector('.arrow').classList.toggle('open');
          } else {
            sub = document.createElement('div');
            sub.dataset.subdir = 'true';
            sub.style.display = 'block';
            div.after(sub);
            await renderDirectory(entry.path, sub, depth + 1);
            div.querySelector('.arrow').classList.add('open');
          }
        };
      } else {
        div.className = 'file';
        div.style.paddingLeft = (padding + 16) + 'px';
        div.textContent = entry.name;
        div.onclick = async () => {
          document.querySelectorAll('.file').forEach(f => f.classList.remove('active'));
          div.classList.add('active');
          try {
            const content = await invoke('read_file_content', { path: entry.path });
            document.getElementById('previewPath').textContent = entry.path;
            const ext = entry.extension.toLowerCase();
            const langMap = {'py':'python','js':'default','ts':'default','sol':'solidity','rs':'rust','go':'go','zig':'cpp','cpp':'cpp','c':'cpp','asm':'asm','sh':'default','cs':'cpp'};
            document.getElementById('previewCode').innerHTML = highlightCode(content, langMap[ext] || 'default');
            currentFilePath = entry.path;
          } catch (e) {
            document.getElementById('previewCode').textContent = `Error reading file: ${e}`;
          }
        };
      }
      container.appendChild(div);
    }
  } catch (e) {
    const err = document.createElement('div');
    err.style.paddingLeft = (padding + 12) + 'px';
    err.style.color = 'var(--red)';
    err.textContent = `Error: ${e}`;
    container.appendChild(err);
  }
}

// ═══ AGENTS ═══
async function loadAgents() {
  const grid = document.querySelector('.agents-grid');
  if (!grid) return;
  grid.innerHTML = '<div style="grid-column:1/-1;color:var(--t3);padding:20px;">Loading agents...</div>';
  try {
    const agents = await invoke('list_agents', {
      agentsDirs: [
        AWEB3_ROOT + '\\.claude\\agents',
        BC_ROOT + '\\.claude\\agents'
      ]
    });
    grid.innerHTML = '';
    for (const agent of agents) {
      const color = agent.project === 'aweb3' ? 'var(--pink)' : 'var(--cyan)';
      const card = document.createElement('div');
      card.className = 'agent-card';
      card.innerHTML = `
        <div class="aname" style="color:${color};">${escapeHtml(agent.name)}</div>
        <div class="ameta">Model: ${escapeHtml(agent.model)} | ${escapeHtml(agent.project)}</div>
        <div class="adesc">${escapeHtml(agent.description.substring(0, 180))}...</div>
        <button data-agent="${escapeHtml(agent.name)}">Launch Agent</button>
      `;
      card.querySelector('button').onclick = () => launchAgent(agent.name);
      grid.appendChild(card);
    }
    if (agents.length === 0) {
      grid.innerHTML = '<div style="grid-column:1/-1;color:var(--t3);padding:20px;">No agents found in .claude/agents/</div>';
    }
  } catch (e) {
    grid.innerHTML = `<div style="grid-column:1/-1;color:var(--red);padding:20px;">Error loading agents: ${escapeHtml(String(e))}</div>`;
  }
}

window.filterAgents = function (filter) {
  const cards = document.querySelectorAll('.agent-card');
  cards.forEach(card => {
    const meta = card.querySelector('.ameta');
    if (!meta) return;
    if (filter === 'all') {
      card.style.display = 'block';
    } else if (filter === 'aweb3') {
      card.style.display = meta.textContent.includes('aweb3') ? 'block' : 'none';
    } else if (filter === 'bc') {
      card.style.display = meta.textContent.includes('BC') || meta.textContent.includes('BlockChainCore') ? 'block' : 'none';
    }
  });
};

async function launchAgent(name) {
  appendToConsole('main', `[INFO] Launching agent: ${name}`);
  try {
    const result = await invoke('launch_agent', { name });
    appendToConsole('main', `[INFO] ${result}`);
  } catch (e) {
    appendToConsole('main', `[ERROR] ${e}`);
  }
}

// ═══ EXPLOITS ═══
async function loadExploits() {
  const list = document.querySelector('.exploit-list');
  if (!list) return;

  // Keep filters, clear items
  const items = list.querySelectorAll('.exploit-item');
  items.forEach(i => i.remove());

  try {
    const blocks = await invoke('list_exploit_blocks', { importedDir: IMPORTED_DIR });

    // Update filter button
    const filterBtn = list.querySelector('.exploit-filters button');
    if (filterBtn) filterBtn.textContent = `All (${blocks.length})`;

    // Show first 50
    const toShow = blocks.slice(0, 50);
    for (const block of toShow) {
      const div = document.createElement('div');
      div.className = 'exploit-item';
      div.innerHTML = `
        <div class="ename">#${block.id} ${escapeHtml(block.file)}</div>
        <div class="elang">${escapeHtml(block.language.toUpperCase())} | ${block.lines} lines | ${block.block_type}</div>
      `;
      div.onclick = () => loadExploitContent(block);
      list.appendChild(div);
    }

    if (blocks.length > 50) {
      const more = document.createElement('div');
      more.className = 'exploit-item';
      more.style.cssText = 'color:var(--t3);font-size:10px;text-align:center;padding:12px;';
      more.textContent = `... +${blocks.length - 50} more exploit blocks`;
      list.appendChild(more);
    }
  } catch (e) {
    const err = document.createElement('div');
    err.className = 'exploit-item';
    err.style.color = 'var(--red)';
    err.textContent = `Error loading exploits: ${e}`;
    list.appendChild(err);
  }
}

async function loadExploitContent(block) {
  const preview = document.querySelector('.exploit-preview');
  if (!preview) return;
  const head = preview.querySelector('.ehead');
  const pre = preview.querySelector('pre');
  if (head) {
    head.innerHTML = `<div><span style="color:var(--red);font-weight:bold;">#${block.id}</span> ${escapeHtml(block.file)} <span style="color:var(--cyan);font-size:10px;">${escapeHtml(block.language.toUpperCase())}</span></div>
      <div style="display:flex;gap:6px;">
        <button style="background:var(--s2);color:var(--text);border:1px solid var(--s3);" onclick="navigator.clipboard.writeText(document.querySelector('.exploit-preview pre').innerText)">Copy</button>
        <button>Import to Project</button>
      </div>`;
  }
  try {
    const content = await invoke('get_block_content', { importedDir: IMPORTED_DIR, file: block.file });
    if (pre) pre.innerHTML = highlightCode(content, block.language);
  } catch (e) {
    if (pre) pre.textContent = `Error loading block: ${e}`;
  }
}

// ═══ STATS & DATA ═══
async function loadStats() {
  try {
    const stats = await invoke('get_project_stats', { sandboxPath: SANDBOX });
    // Update stat numbers
    const statMap = [
      { label: 'Scripts & Tools', key: null, val: (stats.aweb3?.scripts || 0) + (stats.blockchaincore?.tools || 0) },
      { label: 'Claude Agents', key: null, val: (stats.aweb3?.agents || 0) + (stats.blockchaincore?.agents || 0) },
      { label: 'Zig Modules', key: 'zig_modules', project: 'blockchaincore' },
      { label: 'Contracts .sol', key: 'contracts', project: 'aweb3' },
    ];

    document.querySelectorAll('.stats-row .stat').forEach(st => {
      const num = st.querySelector('.num');
      const lbl = st.querySelector('.lbl');
      if (!num || !lbl) return;
      const match = statMap.find(s => lbl.textContent.includes(s.label));
      if (match) {
        if (match.key && stats[match.project]) {
          num.textContent = stats[match.project][match.key] || 0;
        } else if (match.val !== undefined) {
          num.textContent = match.val;
        }
      }
    });
  } catch (e) {
    console.log('Stats load failed:', e);
  }
}

async function loadMythosData() {
  try {
    const data = await fetch('./mythos-data.json').then(r => r.json());
    const s = data.master_index;
    const m = data.module_manifest;
    const score = data.score;
    const total = s.unique_blocks;
    const newb = s.new_blocks;
    const impl = m.total_implemented;
    const mods = m.modules;

    const setText = (sel, txt) => {
      const el = document.querySelector(sel);
      if (el) el.textContent = txt;
    };

    setText('.hdr .score', score + '%');
    setText('.side-score .big', score + '%');
    const sideSub = document.querySelector('.side-score div:nth-child(3)');
    if (sideSub) sideSub.textContent = impl + ' impl | ' + newb + ' new | ' + mods + ' modules';

    document.querySelectorAll('.side-item').forEach(item => {
      if (item.textContent.includes('OmniBus OS')) {
        const b = item.querySelector('.badge');
        if (b) b.textContent = mods + ' mod';
      }
    });

    document.querySelectorAll('.stats-row .stat').forEach(st => {
      const num = st.querySelector('.num');
      const lbl = st.querySelector('.lbl');
      if (!num || !lbl) return;
      if (lbl.textContent.includes('MYTHOS Score')) num.textContent = score + '%';
      if (lbl.textContent.includes('Exploit Blocks')) num.textContent = total;
    });

    document.querySelectorAll('.statusbar div').forEach(div => {
      if (div.textContent.includes('Last run:')) {
        div.innerHTML = `<span class="dot g" style="width:6px;height:6px;"></span> Ready <span class="sep">|</span> Processes: 0 <span class="sep">|</span> Last run: ${score}% <span class="sep">|</span> ${impl} impl, ${newb} new`;
      }
    });
  } catch (e) {
    console.log('mythos-data.json not loaded:', e);
  }
}

// ═══ UTILS ═══
function escapeHtml(text) {
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

window.toggleDir = function (el) {
  const content = el.nextElementSibling;
  if (content && content.style.display !== undefined) {
    content.style.display = content.style.display === 'none' ? 'block' : 'none';
    const arrow = el.querySelector('.arrow');
    if (arrow) arrow.classList.toggle('open');
  }
};

window.previewFile = function (el) {
  document.querySelectorAll('.file').forEach(f => f.classList.remove('active'));
  el.classList.add('active');
  const name = el.dataset?.file || el.textContent;
  const previewPath = document.getElementById('previewPath');
  if (previewPath) previewPath.textContent = name;
};

window.addChatMsg = function (text, sender) {
  if (!text) return;
  const output = document.getElementById('claudeOutput');
  if (!output) return;
  const cls = sender === 'user' ? 'c' : 'p';
  const prefix = sender === 'user' ? 'You' : 'Claude';
  const div = document.createElement('div');
  div.className = cls;
  div.textContent = `${prefix}: ${text}`;
  output.appendChild(div);
  output.scrollTop = output.scrollHeight;
};

window.runInClaude = function (args) {
  window.addChatMsg(`claude ${args}`, 'user');
  window.addChatMsg('Claude CLI integration requires spawn_process with program="claude"', 'claude');
};

window.clearLogs = function () {
  const logs = document.querySelector('#page-logs .console-output');
  if (logs) logs.innerHTML = '';
};

// ═══ TASK MANAGER ═══
async function loadTasks() {
  try {
    const data = await invoke('get_tasks', { mythosDataDir: MYTHOS_DATA });
    const tasks = data.tasks || [];
    const container = document.getElementById('tasksFullList');
    if (!container) return;
    let html = `<div style="display:grid;grid-template-columns:1fr 100px 80px 100px;gap:4px;font-size:11px;">
      <div style="color:var(--accent);font-weight:bold;">Task</div>
      <div style="color:var(--accent);font-weight:bold;">Status</div>
      <div style="color:var(--accent);font-weight:bold;">Priority</div>
      <div style="color:var(--accent);font-weight:bold;">Progress</div>`;
    for (const t of tasks) {
      const statusColor = t.status === 'running' ? 'var(--green)' : t.status === 'queued' ? 'var(--yellow)' : 'var(--t3)';
      const priorityColor = t.priority === 'high' ? 'var(--red)' : t.priority === 'medium' ? 'var(--yellow)' : 'var(--t3)';
      const barColor = t.progress >= 100 ? 'var(--green)' : t.progress > 0 ? 'var(--yellow)' : 'var(--s3)';
      html += `<div style="padding:4px 0;border-top:1px solid var(--border);">${escapeHtml(t.name)}</div>
        <div style="padding:4px 0;border-top:1px solid var(--border);color:${statusColor};">${t.status}</div>
        <div style="padding:4px 0;border-top:1px solid var(--border);color:${priorityColor};">${t.priority}</div>
        <div style="padding:4px 0;border-top:1px solid var(--border);"><div style="background:var(--s3);border-radius:2px;overflow:hidden;height:10px;"><div style="height:100%;background:${barColor};width:${t.progress}%;"></div></div></div>`;
    }
    html += '</div>';
    container.innerHTML = html;
  } catch (e) {
    console.log('Tasks load failed:', e);
  }
}

// ═══ GITHUB ═══
async function loadGitHub() {
  const repos = [
    { path: BC_ROOT, name: 'OmniBus-BlockChainCore', color: 'var(--accent)' },
    { path: AWEB3_ROOT, name: 'OmniBus-aweb3', color: 'var(--pink)' }
  ];
  for (const repo of repos) {
    try {
      const data = await invoke('git_status', { repoPath: repo.path });
      const el = document.getElementById('github-' + repo.name.replace(/[^a-zA-Z0-9]/g, '_'));
      if (el) {
        el.innerHTML = `
          <div style="font-size:12px;font-weight:bold;color:${repo.color};margin-bottom:8px;">${escapeHtml(repo.name)}</div>
          <div style="font-size:11px;color:var(--t2);line-height:1.8;">
            <div>Branch: <span style="color:var(--text);">${escapeHtml(data.branch)}</span></div>
            <div>Last commit: <span style="color:var(--text);">${escapeHtml(data.last_commit_msg)}</span></div>
            <div>Date: <span style="color:var(--text);">${escapeHtml(data.last_commit_date)}</span></div>
            <div>Status: <span style="color:${data.dirty ? 'var(--yellow)' : 'var(--green)'}">${data.dirty ? 'Modified files' : 'Clean'}</span></div>
            ${data.status_lines.length ? `<div style="margin-top:4px;color:var(--yellow);font-size:10px;">${data.status_lines.slice(0,5).map(l => escapeHtml(l)).join('<br>')}</div>` : ''}
          </div>`;
      }
    } catch (e) {
      console.log('GitHub load failed for', repo.name, e);
    }
  }
}

// ═══ IMPORT ═══
async function doImport() {
  const path = prompt('Enter directory path to import:', SANDBOX);
  if (!path) return;
  try {
    const files = await invoke('import_directory', {
      path,
      extensions: ["py", "sol", "rs", "go", "zig", "cpp", "c", "asm", "sh", "js", "ts"]
    });
    const container = document.getElementById('importLog');
    if (container) {
      container.innerHTML = `<div style="color:var(--green);margin-bottom:8px;">Found ${files.length} files</div>
        <div style="max-height:200px;overflow-y:auto;font-size:10px;">
          ${files.slice(0, 50).map(f => `<div>${escapeHtml(f.name)} <span style="color:var(--t3);">(${f.extension})</span></div>`).join('')}
          ${files.length > 50 ? `<div style="color:var(--t3);">... +${files.length - 50} more</div>` : ''}
        </div>`;
    }
  } catch (e) {
    alert('Import failed: ' + e);
  }
}

// ═══ SYNTAX HIGHLIGHTING ═══
function highlightCode(code, lang) {
  if (!code) return '';
  const keywords = {
    python: /\b(def|class|import|from|return|if|else|elif|for|while|try|except|with|as|pass|break|continue|lambda|yield|raise|assert|del|global|nonlocal|True|False|None|and|or|not|in|is)\b/g,
    cpp: /\b(int|char|float|double|void|bool|auto|class|struct|enum|union|public|private|protected|virtual|override|static|const|constexpr|inline|template|typename|namespace|using|new|delete|return|if|else|for|while|do|switch|case|default|break|continue|goto|try|catch|throw|sizeof|typedef|extern|volatile|mutable|explicit|operator|friend)\b/g,
    rust: /\b(fn|let|mut|const|static|struct|enum|impl|trait|use|mod|pub|crate|super|self|return|if|else|match|for|while|loop|break|continue|unsafe|async|await|move|ref|where|type|dyn|as|in| Box|Vec|String|Option|Result|Some|None|Ok|Err)\b/g,
    go: /\b(func|var|const|type|struct|interface|map|chan|package|import|return|if|else|for|range|switch|case|default|break|continue|goto|defer|panic|recover|make|new|len|cap|append|copy|close|select|go)\b/g,
    solidity: /\b(pragma|contract|interface|library|function|modifier|event|struct|enum|mapping|address|uint|int|bool|string|bytes|memory|storage|calldata|public|private|internal|external|pure|view|payable|constant|anonymous|indexed|returns|require|assert|revert|emit|this|super|selfdestruct|delegatecall|call|staticcall|keccak256|sha256|ripemd160|ecrecover|block|msg|tx|now|gasleft|addmod|mulmod)\b/g,
    asm: /\b(mov|push|pop|lea|call|ret|jmp|je|jne|jg|jl|cmp|test|add|sub|mul|div|and|or|xor|not|shl|shr|inc|dec|nop|int|syscall|db|dw|dd|dq|section|global|extern|equ|proc|endp|macro|endm|include|bits|org|align|resb|resw|resd|resq)\b/gi,
    default: /\b(function|var|let|const|return|if|else|for|while|class|import|export|from|new|try|catch|throw|async|await|typeof|instanceof|in|of)\b/g
  };

  let html = escapeHtml(code);

  // Comments (must be first to avoid coloring inside comments)
  html = html.replace(/(# .*$)/gm, '<span style="color:var(--t3)">$1</span>');  // Python/bash
  html = html.replace(/(\/\/.*$)/gm, '<span style="color:var(--t3)">$1</span>'); // C-style single line
  html = html.replace(/(\/\*[\s\S]*?\*\/)/g, '<span style="color:var(--t3)">$1</span>'); // C-style multi line

  // Strings
  html = html.replace(/("(?:[^"\\]|\\.)*"|'(?:[^'\\]|\\.)*')/g, '<span style="color:var(--yellow)">$1</span>');

  // Keywords
  const kw = keywords[lang] || keywords.default;
  html = html.replace(kw, '<span style="color:var(--cyan);font-weight:bold">$&</span>');

  // Numbers
  html = html.replace(/\b(\d+(?:\.\d+)?(?:[eE][+-]?\d+)?)\b/g, '<span style="color:var(--orange)">$1</span>');

  // Functions
  html = html.replace(/\b([a-zA-Z_]\w*)\s*(?=\()/g, '<span style="color:var(--blue)">$1</span>');

  return html;
}

// ═══ INIT ═══
document.addEventListener('DOMContentLoaded', async () => {
  await loadMythosData();
  await loadStats();

  // Wire sidebar console buttons
  document.querySelectorAll('.side-item').forEach(item => {
    const text = item.textContent.trim();
    if (text.includes('CMD Terminal')) item.onclick = () => window.openConsole('cmd');
    if (text.includes('Claude Chat')) item.onclick = () => window.openConsole('claude');
    if (text.includes('Kimi Chat')) item.onclick = () => window.openConsole('kimi');
    if (text.includes('Python REPL')) item.onclick = () => window.openConsole('python');
    if (text.includes('Run MYTHOS')) item.onclick = () => window.openConsole('mythos');
    if (text.includes('Tasks')) item.onclick = () => { window.showPage('tasks'); loadTasks(); };
    if (text.includes('Jobs')) item.onclick = () => window.showPage('jobs');
    if (text.includes('GitHub')) item.onclick = () => { window.showPage('github'); loadGitHub(); };
    if (text.includes('Import')) item.onclick = () => window.showPage('import');
  });

  // Wire Import button
  const importBtn = document.querySelector('#page-import button');
  if (importBtn) importBtn.onclick = doImport;

  // Wire dashboard quick actions
  const runAllBtn = document.querySelector('button[onclick*="Run ALL"]');
  if (runAllBtn) {
    runAllBtn.onclick = () => spawnConsole('mythos-all');
  }

  console.log('MYTHOS LAB initialized');
});
